# ================================
# SERVER CONFIGURATION
# ================================
PORT=5000
NODE_ENV=development
API_VERSION=v1

# ================================
# DATABASE CONFIGURATION
# ================================
# Choose your database: MongoDB or PostgreSQL

# MongoDB Connection String
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/sktours
# For MongoDB Atlas (Production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sktours?retryWrites=true&w=majority

# PostgreSQL Connection String (Neon DB)
# Format: postgresql://user:password@host:port/database?options
POSTGRES_URI=postgresql://neondb_owner:npg_4CeNj3VMXmJg@ep-lingering-fire-aiyplley-pooler.c-4.us-east-1.aws.neon.tech/tripbharat?sslmode=require&channel_binding=require
# For local PostgreSQL:
# POSTGRES_URI=postgresql://username:password@localhost:5432/sktours

# Database Selection (mongodb or postgresql)
DB_TYPE=mongodb

# ================================
# JWT CONFIGURATION
# ================================
# Generate a strong secret key (min 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=24h
JWT_COOKIE_EXPIRE=24

# ================================
# RAZORPAY PAYMENT GATEWAY
# ================================
# Get these from: https://dashboard.razorpay.com/app/keys
# Test Mode Keys:
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
# Live Mode Keys (for production):
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# ================================
# CLOUDINARY IMAGE UPLOAD
# ================================
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
CLOUDINARY_FOLDER=sktours

# ================================
# EMAIL SERVICE (NODEMAILER)
# ================================
# Option 1: Gmail (Recommended for development)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=SK ToursiQ <noreply@sktours.com>

# Option 2: SendGrid (Recommended for production)
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxx

# Option 3: AWS SES
# EMAIL_SERVICE=ses
# AWS_ACCESS_KEY_ID=xxxxx
# AWS_SECRET_ACCESS_KEY=xxxxx
# AWS_REGION=us-east-1

# ================================
# OPENAI / CHATGPT API
# ================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4-turbo-preview
# For AI-powered package recommendations and chatbot

# ================================
# FRONTEND CONFIGURATION
# ================================
# Frontend URL for CORS and email links
FRONTEND_URL=http://localhost:3000
# Production:
# FRONTEND_URL=https://www.sktours.com

# ================================
# THIRD-PARTY APIS (Optional)
# ================================
# Bus Booking API (e.g., RedBus, Goibibo)
BUS_API_KEY=your_bus_api_key
BUS_API_URL=https://api.redbus.in/v1
BUS_API_SECRET=your_bus_api_secret

# Hotel Booking API (e.g., Booking.com, Agoda)
HOTEL_API_KEY=your_hotel_api_key
HOTEL_API_URL=https://api.booking.com/v1
HOTEL_API_SECRET=your_hotel_api_secret

# Flight Booking API (Future feature)
FLIGHT_API_KEY=your_flight_api_key
FLIGHT_API_URL=https://api.skyscanner.net/v1

# ================================
# SMS SERVICE (Optional)
# ================================
# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# MSG91 SMS (India)
MSG91_AUTH_KEY=xxxxxxxxxxxxxxxxxxxxxx
MSG91_SENDER_ID=SKTOUR
MSG91_ROUTE=4

# ================================
# FILE UPLOAD LIMITS
# ================================
MAX_FILE_SIZE=5242880
# 5MB = 5 * 1024 * 1024 bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,image/webp

# ================================
# RATE LIMITING
# ================================
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes = 15 * 60 * 1000
RATE_LIMIT_MAX_REQUESTS=100

# ================================
# REFERRAL REWARDS
# ================================
REFERRAL_REWARD_AMOUNT=500
# Amount in INR to credit when referral is successful
REFERRAL_MIN_BOOKING_AMOUNT=5000
# Minimum booking amount for referral to be valid

# ================================
# BOOKING CONFIGURATION
# ================================
BOOKING_CANCELLATION_HOURS=168
# 7 days = 7 * 24 hours
BOOKING_FULL_REFUND_HOURS=168
BOOKING_PARTIAL_REFUND_HOURS=72
BOOKING_PARTIAL_REFUND_PERCENT=50

# ================================
# TAXES & CHARGES
# ================================
GST_PERCENTAGE=12
# 12% GST on all bookings
CONVENIENCE_FEE_PERCENT=2
# 2% convenience fee

# ================================
# ADMIN CREDENTIALS
# ================================
# Default admin user (created on first run)
ADMIN_NAME=SK ToursiQ Admin
ADMIN_EMAIL=admin@sktours.com
ADMIN_PASSWORD=Admin@123456
ADMIN_PHONE=+91 9876543210

# ================================
# LOGGING
# ================================
LOG_LEVEL=info
# Options: error, warn, info, http, debug
LOG_FILE_PATH=./logs

# ================================
# SECURITY
# ================================
BCRYPT_SALT_ROUNDS=10
PASSWORD_MIN_LENGTH=8
TOKEN_EXPIRY_RESET_PASSWORD=3600000
# 1 hour = 60 * 60 * 1000
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=900000
# 15 minutes = 15 * 60 * 1000

# ================================
# WEBHOOK URLS
# ================================
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx
PAYMENT_SUCCESS_URL=http://localhost:5000/api/payments/success
PAYMENT_FAILURE_URL=http://localhost:5000/api/payments/failure

# ================================
# GOOGLE SERVICES (Optional)
# ================================
# Google Maps API (for location services)
GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth (for social login - future feature)
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxx

# ================================
# REDIS (Optional - for caching)
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600
# 1 hour cache expiry

# ================================
# BACKUP & MONITORING
# ================================
# MongoDB Backup
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 0 * * *
# Daily at midnight (cron format)

# Sentry Error Monitoring
SENTRY_DSN=https://xxxxxx@sentry.io/xxxxxx

# ================================
# MISCELLANEOUS
# ================================
ENABLE_SWAGGER_DOCS=true
SWAGGER_URL=/api-docs
API_DESCRIPTION=SK ToursiQ Travel Booking Platform API
COMPANY_NAME=SK ToursiQ
COMPANY_EMAIL=support@sktours.com
COMPANY_PHONE=+91 1234567890
SUPPORT_URL=https://sktours.com/support
